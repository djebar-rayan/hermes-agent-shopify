# ============================================================
# .env.template — Hermes Shopify Framework
# Copy to /root/.hermes/.env then chmod 600
# Fill in the values marked <to_fill_in>
# ============================================================

# === STORE ===
SHOPIFY_STORE=<store_handle>              # ex: mystore (without .myshopify.com)
SHOP_BRAND_NAME=<Display Name>            # ex: MyStore
SHOP_DOMAIN=<store>.com                   # ex: mystore.com (custom domain)
HERMES_WORKSPACE=/root/<store>-shopify    # ex: /root/mystore-shopify
HERMES_MODE=test                          # test | prod (always start in test)
HERMES_TEST_EMAIL_TO=<your_email>         # recipient in test mode
LIVE_THEME_ID=<numeric_id>                # discover via `shopify theme list`

# === SHOPIFY AUTH ===
# Theme Access token created via https://admin.shopify.com/store/<store>/apps/theme-access
SHOPIFY_CLI_THEME_TOKEN=shptka_<to_fill_in>

# === LLM PROVIDERS ===
# OpenRouter (primary, ~$20/month)
OPENROUTER_API_KEY=sk-or-v1-<to_fill_in>

# Gemini (Google AI Studio) — for image generation + text/vision fallback
GEMINI_API_KEY=AIza<to_fill_in>
GEMINI_MODEL=gemini-3.1-flash-image-preview        # IMAGE generation only
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview    # text
GEMINI_VISION_MODEL=gemini-3.1-flash-lite-preview  # vision

# OpenAI (fallback)
OPENAI_API_KEY=sk-proj-<to_fill_in>
OPENAI_TEXT_MODEL=gpt-4.1-nano
OPENAI_VISION_MODEL=gpt-4.1-nano

# Anthropic (direct LLM backup, optional)
ANTHROPIC_API_KEY=sk-ant-<to_fill_in>
ANTHROPIC_TOKEN=<to_fill_in>

# === EMAIL SMTP (Gmail recommended) ===
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=<your_email>
EMAIL_SMTP_PASSWORD=<16-char_App_Password>  # https://myaccount.google.com/apppasswords
EMAIL_FROM=<your_email>
EMAIL_TO=<your_email>

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=<bot_token>            # via @BotFather
TELEGRAM_ALLOWED_USERS=<user_id>          # via @userinfobot (your Telegram user_id)
TELEGRAM_HOME_CHANNEL=<user_id>           # same value as TELEGRAM_ALLOWED_USERS

# === KLAVIYO (optional but recommended) ===
KLAVIYO_API_KEY=pk_<to_fill_in>           # Private Key, read-only

# === FIRECRAWL (competitive monitoring, optional) ===
FIRECRAWL_API_KEY=fc-<to_fill_in>

# === GOOGLE SEARCH CONSOLE (optional) ===
GSC_SERVICE_ACCOUNT_FILE=/root/.hermes/gsc-service-account.json
GSC_CLIENT_EMAIL=<service-account>@<gcp-project>.iam.gserviceaccount.com
GSC_PROJECT_ID=<gcp-project>
GSC_SITE_URL=sc-domain:<store>.com

# === BROWSER (optional, for stealth web tools) ===
BROWSERBASE_ADVANCED_STEALTH=true
BROWSERBASE_PROXIES=true
BROWSER_INACTIVITY_TIMEOUT=300
BROWSER_SESSION_TIMEOUT=3600

# === MEMORY PROVIDER ===
OPENVIKING_ENDPOINT=http://localhost:1933

# ============================================================
# Security:
# - chmod 600 this file after filling it in
# - NEVER commit to git
# - The framework's .gitignore already blocks this file
# ============================================================
