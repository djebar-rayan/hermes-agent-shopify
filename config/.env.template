# ============================================================
# .env.template — Hermes Shopify Framework
# Copier vers /root/.hermes/.env puis chmod 600
# Remplir les valeurs marquées <à_remplir>
# ============================================================

# === BOUTIQUE ===
SHOPIFY_STORE=<store_handle>              # ex: mystore (sans .myshopify.com)
SHOP_BRAND_NAME=<Display Name>            # ex: MyStore
SHOP_DOMAIN=<store>.com                   # ex: mystore.com (domaine custom)
HERMES_WORKSPACE=/root/<store>-shopify    # ex: /root/mystore-shopify
HERMES_MODE=test                          # test | prod (toujours démarrer en test)
HERMES_TEST_EMAIL_TO=<your_email>         # destinataire en mode test
LIVE_THEME_ID=<numeric_id>                # à découvrir via `shopify theme list`

# === SHOPIFY AUTH ===
# Theme Access token créé via https://admin.shopify.com/store/<store>/apps/theme-access
SHOPIFY_CLI_THEME_TOKEN=shptka_<à_remplir>

# === LLM PROVIDERS ===
# OpenRouter (principal, ~20$/mois)
OPENROUTER_API_KEY=sk-or-v1-<à_remplir>

# Gemini (Google AI Studio) — pour génération images + fallback text/vision
GEMINI_API_KEY=AIza<à_remplir>
GEMINI_MODEL=gemini-3.1-flash-image-preview        # IMAGE generation uniquement
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview    # text
GEMINI_VISION_MODEL=gemini-3.1-flash-lite-preview  # vision

# OpenAI (fallback)
OPENAI_API_KEY=sk-proj-<à_remplir>
OPENAI_TEXT_MODEL=gpt-4.1-nano
OPENAI_VISION_MODEL=gpt-4.1-nano

# Anthropic (backup LLM direct, optionnel)
ANTHROPIC_API_KEY=sk-ant-<à_remplir>
ANTHROPIC_TOKEN=<à_remplir>

# === EMAIL SMTP (Gmail recommandé) ===
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=<your_email>
EMAIL_SMTP_PASSWORD=<16-char_App_Password>  # https://myaccount.google.com/apppasswords
EMAIL_FROM=<your_email>
EMAIL_TO=<your_email>

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=<bot_token>            # via @BotFather
TELEGRAM_ALLOWED_USERS=<user_id>          # via @userinfobot (ton user_id Telegram)
TELEGRAM_HOME_CHANNEL=<user_id>           # même valeur que TELEGRAM_ALLOWED_USERS

# === KLAVIYO (optionnel mais recommandé) ===
KLAVIYO_API_KEY=pk_<à_remplir>            # Private Key, read-only

# === FIRECRAWL (veille concurrentielle, optionnel) ===
FIRECRAWL_API_KEY=fc-<à_remplir>

# === GOOGLE SEARCH CONSOLE (optionnel) ===
GSC_SERVICE_ACCOUNT_FILE=/root/.hermes/gsc-service-account.json
GSC_CLIENT_EMAIL=<service-account>@<gcp-project>.iam.gserviceaccount.com
GSC_PROJECT_ID=<gcp-project>
GSC_SITE_URL=sc-domain:<store>.com

# === BROWSER (optionnel, pour tools web stealth) ===
BROWSERBASE_ADVANCED_STEALTH=true
BROWSERBASE_PROXIES=true
BROWSER_INACTIVITY_TIMEOUT=300
BROWSER_SESSION_TIMEOUT=3600

# === MEMORY PROVIDER ===
OPENVIKING_ENDPOINT=http://localhost:1933

# ============================================================
# Sécurité :
# - chmod 600 ce fichier après remplissage
# - JAMAIS commit dans git
# - Le .gitignore du framework bloque déjà ce fichier
# ============================================================
